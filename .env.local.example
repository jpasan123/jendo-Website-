# Jendo Chatbot Configuration

# Auth service used to obtain a bearer token before calling the chatbot backend
CHATBOT_AUTH_URL=http://188.166.240.119:8080/api/auth/login
CHATBOT_AUTH_EMAIL=
CHATBOT_AUTH_PASSWORD=

# Spring Boot Chatbot Backend API URL
CHATBOT_BACKEND_URL=http://188.166.240.119:8090/api/chatbot/message

# Optional static token if the proxy must call the chatbot service directly
CHATBOT_BACKEND_TOKEN=

# Hugging Face API Token (OPTIONAL - for higher rate limits)
# Get free token at: https://huggingface.co/settings/tokens
# Without token: ~50-100 requests/hour
# With token: 1000+ requests/hour
HUGGINGFACE_TOKEN=

# Next.js Configuration
NEXT_PUBLIC_GA_ID=your_google_analytics_id
